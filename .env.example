# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Stripe secret key. Use a TEST key (sk_test_...) for development.
# Get this from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me

# Optional: webhook signing secret if you wire up /api/stripe-webhook
# STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Public site URL Stripe will redirect back to after Checkout
# In dev this is typically http://localhost:8000 or wherever the static site is served
PUBLIC_SITE_URL=http://localhost:8000

# Currency for Checkout (ISO code). TKS prices are in GBP.
STRIPE_CURRENCY=gbp
